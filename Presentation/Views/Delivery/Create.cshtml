@model CreateOrderDto

<h2 class="mb-4">
    🚚 Новый заказ
</h2>


<div class="card shadow">

    <div class="card-body">

        <form asp-action="Create" method="post">

            <h5>Отправитель</h5>

            <div class="row">

                <div class="col-md-6 mb-3">

                    <label class="form-label">
                        Город
                    </label>

                    <input class="form-control"
                           asp-for="SenderCity" />

                    <span class="text-danger"
                          asp-validation-for="SenderCity">
                    </span>

                </div>


                <div class="col-md-6 mb-3">

                    <label class="form-label">
                        Адрес
                    </label>

                    <input class="form-control"
                           asp-for="SenderAddress" />

                    <span class="text-danger"
                          asp-validation-for="SenderAddress">
                    </span>

                </div>

            </div>



            <h5 class="mt-3">
                Получатель
            </h5>


            <div class="row">

                <div class="col-md-6 mb-3">

                    <label class="form-label">
                        Город
                    </label>

                    <input class="form-control"
                           asp-for="RecipientCity" />

                    <span class="text-danger"
                          asp-validation-for="RecipientCity">
                    </span>

                </div>


                <div class="col-md-6 mb-3">

                    <label class="form-label">
                        Адрес
                    </label>

                    <input class="form-control"
                           asp-for="RecipientAddress" />

                    <span class="text-danger"
                          asp-validation-for="RecipientAddress">
                    </span>

                </div>

            </div>



            <div class="row">


                <div class="col-md-6 mb-3">

                    <label class="form-label">
                        Вес (кг)
                    </label>

                    <input class="form-control"
                           asp-for="CargoWeight" />

                    <span class="text-danger"
                          asp-validation-for="CargoWeight">
                    </span>

                </div>



                <div class="col-md-6 mb-3">

                    <label class="form-label">
                        Дата забора
                    </label>

                    <input type="date"
                           class="form-control"
                           asp-for="PickupDate" />

                    <span class="text-danger"
                          asp-validation-for="PickupDate">
                    </span>

                </div>


            </div>



            <button class="btn btn-success">
                Создать заказ
            </button>


            <a class="btn btn-secondary"
               asp-action="Index">
                Назад
            </a>


        </form>


    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}